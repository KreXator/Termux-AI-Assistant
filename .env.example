# Termux AI Assistant — Configuration
# Copy this to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram user IDs (comma-separated, leave empty to allow all)
ALLOWED_USER_IDS=

# Ollama configuration
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model routing — set your preferred models
# SMALL: fast model for simple tasks (intent detection, notes, chat)
MODEL_SMALL=llama3.2:3b

# LARGE: heavy model for coding, reasoning, complex tasks
MODEL_LARGE=llama3:8b

# Token threshold — summarise conversation when it exceeds this
CONTEXT_TOKEN_LIMIT=3000

# Base directory for data storage (JSON files)
DATA_DIR=./data
