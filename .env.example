# Windows AI Assistant — Configuration
# Copy this to .env and fill in your values

# ─── Required ─────────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─── Access Control ───────────────────────────────────────────────────────────

# Allowed Telegram user IDs (comma-separated). Leave empty to allow everyone.
# Also required to enable /run (code execution).
ALLOWED_USER_IDS=

# ─── OpenRouter (Primary LLM) ─────────────────────────────────────────────────

# Get a free key at https://openrouter.ai/settings/keys
# When set, OpenRouter is used as primary; Ollama becomes the fallback.
OPENROUTER_API_KEY=

# Model tiers — built-in defaults shown, override only if needed.
# Estimated cost at ~100 msg/day: ~$0.15-0.40/month total.
#
#   small  (💬) free   — routing, simple tasks         [free]
#   medium (⚡) paid   — daily driver, best Polish      [$0.15/$0.60 per M]
#   large  (🧠) paid   — complex tasks, code, Intel 23  [$0.40/$1.60 per M]
#   premium(💰) paid   — best available, /model premium  [$0.30/$2.50 per M]
#
#OR_MODEL_SMALL=google/gemma-3-4b-it:free
#OR_MODEL_MEDIUM=mistralai/mistral-small-2603
#OR_MODEL_LARGE=openai/gpt-4.1-mini
#OR_MODEL_PREMIUM=google/gemini-2.5-flash
#OR_MODEL_CODER=openai/gpt-4.1-mini
#OR_VISION_MODEL=google/gemma-3-12b-it:free

# ─── Ollama (Local LLM — fallback) ────────────────────────────────────────────

OLLAMA_BASE_URL=http://127.0.0.1:11434

# Local model names used when Ollama is the active provider
# (also used as tier identifiers for OpenRouter model mapping)
MODEL_SMALL=qwen2.5:3b-instruct-q4_K_M
MODEL_MEDIUM=qwen2.5:7b-instruct-q4_K_M
MODEL_LARGE=qwen3:8b

# History pruning — two limits, both apply:
#   HISTORY_CHARS  — character budget (1 token ≈ 4 chars).
#                    200 000 chars ≈ 50 000 tokens — safe for 131K-context models.
#                    Increase to 600 000 if using Gemini 2.5 (1M context).
#   HISTORY_WINDOW — max number of messages (safety cap, rarely hit).
HISTORY_CHARS=200000
HISTORY_WINDOW=100

# Ollama vision model (fallback when OpenRouter vision fails)
VISION_MODEL=llava:7b

# ─── Web Search ───────────────────────────────────────────────────────────────

# Serper.dev Google Search API key (optional — falls back to DuckDuckGo scrape)
# Get a free key (2500 searches/month) at https://serper.dev
SERPER_API_KEY=

# ─── Voice Transcription ──────────────────────────────────────────────────────

# Groq API key for Whisper voice transcription (optional)
# Free tier: 28,800 seconds/day. Get key at https://console.groq.com
GROQ_API_KEY=

# ─── Scheduler ────────────────────────────────────────────────────────────────

# Timezone for scheduled searches (IANA format)
TZ=Europe/Warsaw

# ─── Turso (Cloud SQLite — shared state across devices) ───────────────────────

# Get from https://turso.tech — free tier includes 9 GB storage
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# ─── Storage (legacy — no longer used when Turso is configured) ───────────────

# Base directory for data storage (JSON files — kept for migration script)
DATA_DIR=./data
