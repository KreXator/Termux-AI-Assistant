# Windows AI Assistant — Configuration
# Copy this to .env and fill in your values

# ─── Required ─────────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─── Access Control ───────────────────────────────────────────────────────────

# Allowed Telegram user IDs (comma-separated). Leave empty to allow everyone.
# Also required to enable /run (code execution).
ALLOWED_USER_IDS=

# ─── OpenRouter (Primary LLM — cloud, free models) ────────────────────────────

# Get a free key at https://openrouter.ai/settings/keys
# When set, OpenRouter is used as primary; Ollama becomes the fallback.
OPENROUTER_API_KEY=

# OpenRouter free model overrides (defaults = Google Gemma via Google AI Studio)
# Venice-hosted models (Llama, Mistral, Qwen :free) are often rate-limited — avoid them.
#OR_MODEL_SMALL=google/gemma-3-4b-it:free
#OR_MODEL_MEDIUM=google/gemma-3-12b-it:free
#OR_MODEL_LARGE=google/gemma-3-27b-it:free
#OR_VISION_MODEL=google/gemma-3-12b-it:free

# Optional paid model — activate manually with /model premium in the bot
# Best value: $0.40/M output, 1M context, excellent Polish, natively multimodal
# Alternatives: openai/gpt-4o-mini ($0.60/M), openai/gpt-4.1-nano ($0.40/M)
#OR_MODEL_PREMIUM=google/gemini-2.5-flash-lite

# ─── Ollama (Local LLM — fallback) ────────────────────────────────────────────

OLLAMA_BASE_URL=http://127.0.0.1:11434

# Local model names used when Ollama is the active provider
# (also used as tier identifiers for OpenRouter model mapping)
MODEL_SMALL=qwen2.5:3b-instruct-q4_K_M
MODEL_MEDIUM=qwen2.5:7b-instruct-q4_K_M
MODEL_LARGE=qwen3:8b

# Conversation history window (number of messages kept per user)
HISTORY_WINDOW=10

# Ollama vision model (fallback when OpenRouter vision fails)
VISION_MODEL=llava:7b

# ─── Web Search ───────────────────────────────────────────────────────────────

# Serper.dev Google Search API key (optional — falls back to DuckDuckGo scrape)
# Get a free key (2500 searches/month) at https://serper.dev
SERPER_API_KEY=

# ─── Voice Transcription ──────────────────────────────────────────────────────

# Groq API key for Whisper voice transcription (optional)
# Free tier: 28,800 seconds/day. Get key at https://console.groq.com
GROQ_API_KEY=

# ─── Scheduler ────────────────────────────────────────────────────────────────

# Timezone for scheduled searches (IANA format)
TZ=Europe/Warsaw

# ─── Storage ──────────────────────────────────────────────────────────────────

# Base directory for data storage (JSON files)
DATA_DIR=./data
