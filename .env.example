# Windows AI Assistant — Configuration
# Copy this to .env and fill in your values

# ─── Required ─────────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─── Access Control ───────────────────────────────────────────────────────────

# Allowed Telegram user IDs (comma-separated). Leave empty to allow everyone.
# Also required to enable /run (code execution).
ALLOWED_USER_IDS=

# ─── Ollama (Local LLM) ───────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://127.0.0.1:11434

# 3-tier model routing
MODEL_SMALL=qwen2.5:3b-instruct-q4_K_M
MODEL_MEDIUM=qwen2.5:7b-instruct-q4_K_M
MODEL_LARGE=qwen3:8b

# Conversation history window (number of messages kept per user)
HISTORY_WINDOW=10

# Vision model for image analysis (must support images in Ollama)
VISION_MODEL=llava:7b

# ─── Web Search ───────────────────────────────────────────────────────────────

# Serper.dev Google Search API key (optional — falls back to DuckDuckGo scrape)
# Get a free key (2500 searches/month) at https://serper.dev
SERPER_API_KEY=

# ─── Voice Transcription ──────────────────────────────────────────────────────

# Groq API key for Whisper voice transcription (optional)
# Free tier: 28,800 seconds/day. Get key at https://console.groq.com
GROQ_API_KEY=

# ─── Scheduler ────────────────────────────────────────────────────────────────

# Timezone for scheduled searches (IANA format)
TZ=Europe/Warsaw

# ─── Storage ──────────────────────────────────────────────────────────────────

# Base directory for data storage (JSON files)
DATA_DIR=./data
